---
// MainLayout.astro - Global Template for Auto Reservation Plus
const { title = "Auto Reservation Plus | Car Hire" } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
        /* Modern CSS Reset & Globals */
        :root { 
            --brand-blue: #2BA6CB; 
            --brand-blue-dark: #2284A2;
            --dark-bg: #1A1D21; /* A modern, soft black for nav */
            --light-bg: #f8f9fa;
            --text-main: #333;
            --nav-height: 70px;
        }
        * { box-sizing: border-box; }
        body { 
            margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
            background: var(--light-bg); color: var(--text-main); line-height: 1.5; -webkit-font-smoothing: antialiased; 
        }
        
        /* Global Layout Container (990px) */
        .container { max-width: 990px; width: 100%; margin: 0 auto; padding: 0 20px; }
        
        /* Modern Header */
        header.top-header { background: white; height: var(--nav-height); border-bottom: 1px solid #eee; display: flex; align-items: center; position: sticky; top: 0; z-index: 1000; }
        .nav-flex { display: flex; justify-content: space-between; align-items: center; width: 100%; }
        
        .logo h2 { margin: 0; font-size: 1.4rem; color: var(--brand-blue); letter-spacing: -1px; }
        
        nav ul { list-style: none; margin: 0; padding: 0; display: flex; gap: 5px; }
        nav a { text-decoration: none; color: #555; font-size: 14px; font-weight: 600; padding: 10px 15px; border-radius: 4px; transition: 0.2s; }
        nav a:hover { background: #f0f0f0; color: var(--brand-blue); }
        nav a.active { background: var(--brand-blue); color: white; }

        .tel-link { font-weight: 700; color: var(--brand-blue); font-size: 15px; text-decoration: none; }
        
        /* Global Footer */
        footer { background: white; padding: 60px 0; margin-top: auto; border-top: 1px solid #eee; }
        .footer-grid { text-align: center; color: #777; font-size: 14px; }
    </style>
</head>
<body>
    <header class="top-header">
        <div class="container nav-flex">
            <div class="logo"><a href="/" style="text-decoration:none;"><h2>AUTO RESERVATION PLUS</h2></a></div>
            <nav>
                <ul>
                    <li><a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Home</a></li>
                    <li><a href="/manage-booking" class={Astro.url.pathname === '/manage-booking' ? 'active' : ''}>Manage Booking</a></li>
                </ul>
            </nav>
            <a href="tel:+4401622631146" class="tel-link">Call: +44(0)1622 631146</a>
        </div>
    </header>

    <main>
        <slot /> </main>

    <footer>
        <div class="container footer-grid">
            &copy; {new Date().getFullYear()} Auto Reservation Plus Limited. Registered in England & Wales.
        </div>
    </footer>
</body>
</html>