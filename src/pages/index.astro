---
// Auto Reservation Plus - Precision 2-Column Build
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Holiday Car Rentals | Auto Reservation Plus</title>
    <style is:global>
        :root { 
            --brand-blue: #2BA6CB; 
            --dark-text: #333; 
            --light-bg: #f4f4f4; 
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Helvetica Neue', Arial, sans-serif; background: var(--light-bg); line-height: 1.5; }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header */
        header { background: white; padding: 15px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); text-transform: uppercase; font-size: 1.4rem; }
        .phone { font-weight: bold; color: var(--brand-blue); }
        
        /* Navigation */
        nav { background: #333; position: sticky; top: 0; z-index: 1000; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 15px 25px; color: white; text-decoration: none; font-weight: bold; font-size: 14px; }
        nav .nav-flex li a:hover { background-color: var(--brand-blue) !important; }

        /* Hero Grid */
        .hero-grid-wrapper {
            width: 100%;
            min-height: 600px;
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), 
                        url('https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
        }
        .hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; align-items: start; padding: 40px 0; }
        
        .hero-left-text { color: white; padding-top: 20px; }
        .hero-left-text h1 { font-size: 4rem; margin: 0; line-height: 1; font-weight: 800; }
        
        .check-list { list-style: none; padding: 0; margin: 30px 0 0 0; }
        .check-list li { font-size: 1.2rem; margin-bottom: 12px; display: flex; align-items: center; font-weight: 500; }
        .check-list li::before {
            content: '✓'; display: inline-block; width: 24px; height: 24px; background: var(--brand-blue);
            color: white; border-radius: 50%; text-align: center; line-height: 24px; margin-right: 12px; font-weight: bold; font-size: 14px;
        }

        /* --- THE SEARCH BOX FIX --- */
        .engine-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
            overflow: hidden; /* Clips any "unwanted extra padding" from the engine */
            width: 100%;
            max-width: 400px;
            margin-left: auto;
        }

        /* Force Remove Internal Widget Backgrounds */
        #ct-mount-point, .ct-step-1-container, .ct-search-container {
            background-color: #ffffff !important;
            background: #ffffff !important;
            padding: 0 !important;
        }

        /* FORCE THE BUTTON COLOR (Targets multiple possible V5 classes) */
        button.ct-btn-search, 
        .ct-btn-search,
        .ct-btn-search-container button,
        [type="submit"].ct-btn-search {
            background: var(--brand-blue) !important;
            background-color: var(--brand-blue) !important;
            background-image: none !important;
            border: none !important;
            color: white !important;
            height: 50px !important;
            border-radius: 4px !important;
        }

        @media (max-width: 992px) {
            .hero-grid { grid-template-columns: 1fr; text-align: center; }
            .engine-card { margin: 0 auto; }
            .check-list { display: inline-block; text-align: left; }
        }
    </style>
</head>
<body>

    <header>
        <div class="container top-flex">
            <div class="logo-area"><h2>Auto Reservation Plus</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav>
        <div class="container">
            <ul class="nav-flex">
                <li><a href="/">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero-grid-wrapper">
        <div class="container">
            <div class="hero-grid">
                <div class="hero-left-text">
                    <h1>Holiday Car Rentals</h1>
                    <ul class="check-list">
                        <li>Free Cancellation</li>
                        <li>No Hidden Charges</li>
                        <li>800+ Suppliers Worldwide</li>
                        <li>24/7 Customer Support</li>
                    </ul>
                </div>
                <div class="hero-right-engine">
                    <div class="engine-card">
                        <div style="height: 410px; overflow: hidden;">
                            <div ct-app id="ct-mount-point"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer style="text-align: center; padding: 40px; color: #999; font-size: 13px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        /* --- CARTRAWLER CONFIG --- */
        var CT = {
          ABE: {
            Settings: {
              clientID: '315556',
              // Force detection logic from FAQ
              type: window.innerWidth < 800 ? 'mobile' : 'desktop',
              step1: {
                deeplinkURL: 'https://book.cartrawler.com/?clientID=315556',
                showAvailNewWindow: false
              }
            }
          }
        };

        (function() {
          CT.ABE.Settings.version = '5.0';
          var cts = document.createElement('script'); 
          cts.type = 'text/javascript'; cts.async = true;
          cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
          var s = document.getElementsByTagName('script')[0]; 
          s.parentNode.insertBefore(cts, s);
        })();

        /* --- THE STUBBORN COLOR FIXER --- */
        // This script waits for the engine to load, then forces the button color one last time
        const colorFixer = setInterval(() => {
            const btn = document.querySelector('.ct-btn-search');
            if (btn) {
                btn.style.backgroundColor = '#2BA6CB';
                btn.style.backgroundImage = 'none';
                // Once we find it and fix it, we stop looking
                clearInterval(colorFixer);
            }
        }, 500);
    </script>
</body>
</html>