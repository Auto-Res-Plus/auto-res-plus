---
// Auto Reservation Plus - Polished 2-Column Grid
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Auto Reservation Plus | Holiday Car Rentals</title>
    <style>
        :root { 
            --brand-blue: #2BA6CB; 
            --dark-text: #333; 
            --light-bg: #f4f4f4; 
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Helvetica Neue', Arial, sans-serif; background: var(--light-bg); color: var(--dark-text); }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header & Nav */
        header { background: white; padding: 15px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); text-transform: uppercase; font-size: 1.4rem; letter-spacing: 1px; }
        .phone { font-weight: bold; color: var(--brand-blue); }
        
        nav { background: #333; position: sticky; top: 0; z-index: 1000; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 15px 25px; color: white; text-decoration: none; font-weight: bold; font-size: 14px; }
        nav .nav-flex li a:hover { background-color: var(--brand-blue) !important; }

        /* --- THE GRID HERO --- */
        .hero-grid-wrapper {
            width: 100%;
            min-height: 650px;
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), 
                        url('https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr; /* Text side slightly wider */
            gap: 60px;
            align-items: center;
        }

        .hero-left-text { color: white; }
        .hero-left-text h1 { font-size: 4.2rem; margin: 0; line-height: 1; text-shadow: 0 2px 15px rgba(0,0,0,0.5); font-weight: 800; }
        
        /* Bullet List Styling */
        .check-list { list-style: none; padding: 0; margin: 30px 0 0 0; }
        .check-list li { 
            font-size: 1.3rem; 
            margin-bottom: 15px; 
            display: flex; 
            align-items: center; 
            text-shadow: 0 1px 5px rgba(0,0,0,0.5);
        }
        .check-list li::before {
            content: '✓';
            display: inline-block;
            width: 28px;
            height: 28px;
            background: var(--brand-blue);
            color: white;
            border-radius: 50%;
            text-align: center;
            line-height: 28px;
            margin-right: 15px;
            font-size: 16px;
            font-weight: bold;
            flex-shrink: 0;
        }

        /* --- THE SEARCH BOX (RIGHT SIDE) --- */
        .engine-container {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.4);
        }

        /* --- CUSTOM WIDGET OVERRIDES --- */
        /* Forces the widget background to be white/transparent */
        [ct-app] .ct-step-1-container, 
        [ct-app] .ct-search-container { 
            background: transparent !important; 
            border: none !important; 
        }

        /* FORCES THE SEARCH BUTTON TO BRAND BLUE */
        [ct-app] .ct-btn-search,
        [ct-app] button[type="submit"] {
            background-color: var(--brand-blue) !important;
            border-color: var(--brand-blue) !important;
            background-image: none !important;
            font-weight: bold !important;
            text-transform: uppercase !important;
            height: 55px !important;
        }

        /* Responsive Fix */
        @media (max-width: 992px) {
            .hero-grid { grid-template-columns: 1fr; padding: 40px 0; }
            .hero-left-text h1 { font-size: 3rem; text-align: center; }
            .check-list { display: inline-block; text-align: left; width: 100%; max-width: 400px; margin: 30px auto; }
            .hero-left-text { text-align: center; }
        }
    </style>
</head>
<body>

    <header>
        <div class="container top-flex">
            <div class="logo-area"><h2>Auto Reservation Plus</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav>
        <div class="container">
            <ul class="nav-flex">
                <li><a href="/">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero-grid-wrapper">
        <div class="container">
            <div class="hero-grid">
                
                <div class="hero-left-text">
                    <h1>Holiday Car Rentals</h1>
                    <ul class="check-list">
                        <li>Free Cancellation</li>
                        <li>No Hidden Charges</li>
                        <li>800+ Suppliers Worldwide</li>
                        <li>24/7 Customer Support</li>
                    </ul>
                </div>

                <div class="hero-right-engine">
                    <div class="engine-container">
                        <div ct-app>
                            </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <footer style="text-align: center; padding: 60px; color: #999; font-size: 13px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        var CT = {
          ABE: {
            Settings: {
              clientID: '315556',
              type: window.innerWidth < 992 ? 'mobile' : 'desktop',
              step1: {
                deeplinkURL: 'https://book.cartrawler.com/?clientID=315556',
                showAvailNewWindow: false
              }
            }
          }
        };

        (function() {
          CT.ABE.Settings.version = '5.0';
          var cts = document.createElement('script'); 
          cts.type = 'text/javascript'; cts.async = true;
          cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
          var s = document.getElementsByTagName('script')[0]; 
          s.parentNode.insertBefore(cts, s);
        })();
    </script>
</body>
</html>