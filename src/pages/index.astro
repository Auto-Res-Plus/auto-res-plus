---
// Auto Reservation Plus - 2 Column Grid (Option 1)
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Auto Reservation Plus | 2-Column Layout</title>
    <style>
        :root { --brand-blue: #2BA6CB; --dark-text: #333; --light-bg: #f4f4f4; }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: Arial, sans-serif; background: var(--light-bg); }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header & Nav */
        header { background: white; padding: 15px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); text-transform: uppercase; font-size: 1.4rem; }
        
        nav { background: #333; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 15px 20px; color: white; text-decoration: none; font-weight: bold; }
        nav .nav-flex li a:hover { background-color: var(--brand-blue) !important; }

        /* --- THE GRID HERO --- */
        .hero-grid-wrapper {
            width: 100%;
            min-height: 600px;
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), 
                        url('https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr; /* Two equal columns */
            gap: 40px;
            align-items: center;
            width: 100%;
        }

        .hero-left-text { color: white; }
        .hero-left-text h1 { font-size: 4rem; margin: 0; line-height: 1.1; text-shadow: 0 2px 10px rgba(0,0,0,0.5); }
        .hero-left-text p { font-size: 1.4rem; margin-top: 20px; opacity: 0.9; }

        /* The Search Box Container (Right Side) */
        .engine-container {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
            min-height: 400px; /* Gives the engine space to load */
        }

        /* Responsive Fix: Stack on mobile */
        @media (max-width: 992px) {
            .hero-grid { grid-template-columns: 1fr; text-align: center; padding: 40px 0; }
            .hero-left-text h1 { font-size: 2.5rem; }
            .hero-grid-wrapper { min-height: auto; }
        }
    </style>
</head>
<body>

    <header>
        <div class="container top-flex">
            <div class="logo-area"><h2>Auto Reservation Plus</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav>
        <div class="container">
            <ul class="nav-flex">
                <li><a href="/">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero-grid-wrapper">
        <div class="container">
            <div class="hero-grid">
                
                <div class="hero-left-text">
                    <h1>Holiday Car Rentals</h1>
                    <p>Compare the best prices from over 800 suppliers worldwide. Simple, fast, and secure.</p>
                </div>

                <div class="hero-right-engine">
                    <div class="engine-container">
                        <div ct-app>
                            </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <footer style="text-align: center; padding: 60px; color: #999;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        var CT = {
          ABE: {
            Settings: {
              clientID: '315556',
              // Force mobile engine if the container gets too narrow
              type: window.innerWidth < 992 ? 'mobile' : 'desktop',
              step1: {
                deeplinkURL: 'https://book.cartrawler.com/?clientID=315556',
                showAvailNewWindow: false
              }
            }
          }
        };

        (function() {
          CT.ABE.Settings.version = '5.0';
          var cts = document.createElement('script'); 
          cts.type = 'text/javascript'; cts.async = true;
          cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
          var s = document.getElementsByTagName('script')[0]; 
          s.parentNode.insertBefore(cts, s);
        })();
    </script>
</body>
</html>