---
// Auto Reservation Plus - Refined Grid & Padding Fix
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Holiday Car Rentals | Auto Reservation Plus</title>
    <style is:global>
        :root { 
            --brand-blue: #2BA6CB; 
            --brand-green: #99CC00;
            --dark-text: #333; 
            --light-bg: #f4f4f4; 
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Helvetica Neue', Arial, sans-serif; background: var(--light-bg); line-height: 1.5; }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        header { background: white; padding: 15px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area {line-height: 0;}
        .logo-area img { max-width: 300px; }
        .phone { font-weight: bold; color: var(--brand-blue); }
        
        nav { background: #333; position: sticky; top: 0; z-index: 1000; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 15px 25px; color: white; text-decoration: none; font-weight: bold; font-size: 14px; }

        /* --- THE HERO GRID --- */
        .hero-grid-wrapper {
            width: 100%;
            min-height: 550px;
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), 
                        url('/images/hero-bg.webp');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
        }
        .hero-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; align-items: center; padding: 40px 0; }
        
        .hero-left-text { color: white; }
        /* Reduced H1 Size */
        .hero-left-text h1 { font-size: 3.2rem; margin: 0; line-height: 1.1; font-weight: 800; text-shadow: 0 2px 10px rgba(0,0,0,0.3); }
        
        .check-list { list-style: none; padding: 0; margin: 25px 0 0 0; }
        .check-list li { font-size: 1.15rem; margin-bottom: 10px; display: flex; align-items: center; font-weight: 500; }
        .check-list li::before {
            content: '✓'; display: inline-block; width: 22px; height: 22px; background: var(--brand-green);
            color: white; border-radius: 50%; text-align: center; line-height: 22px; margin-right: 12px; font-weight: bold; font-size: 12px;
        }

        /* --- THE SEARCH BOX FIX --- */
        .engine-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
            /* Internal padding so fields don't touch the card edges */
            padding: 25px; 
            width: 100%;
            max-width: 420px;
            margin-left: auto;
            position: relative;
        }

        /* Kill the extra gap below the button by forcing the CT container to collapse */
        [ct-app], .ct-step-1-container, .ct-search-container {
            background: transparent !important;
            margin: 0 !important;
            padding: 0 !important;
            height: auto !important;
        }

        /* Nuclear Color Fix for Button */
        .ct-btn-search, button.ct-btn-search {
            background-color: #2BA6CB !important;
            background-image: none !important;
            border: none !important;
            color: white !important;
            box-shadow: 0 4px 0 #1e7a96 !important; /* Adds a little "clicky" depth */
        }

        @media (max-width: 992px) {
            .hero-grid { grid-template-columns: 1fr; text-align: center; }
            .engine-card { margin: 20px auto 0; }
            .hero-left-text h1 { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

    <header>
        <div class="container top-flex">
            <div class="logo-area"><img src="/images/logo.png" alt="Auto Reservation Plus logo"></div>
            <div class="phone">Tel: +44(0)7377 753990</div>
        </div>
    </header>

    <nav>
        <div class="container">
            <ul class="nav-flex">
                <li><a href="/">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero-grid-wrapper">
        <div class="container">
            <div class="hero-grid">
                <div class="hero-left-text">
                    <h1>Holiday Car Rentals</h1>
                    <ul class="check-list">
                        <li>Free Cancellation</li>
                        <li>No Hidden Charges</li>
                        <li>800+ Suppliers Worldwide</li>
                        <li>24/7 Customer Support</li>
                    </ul>
                </div>
                <div class="hero-right-engine">
                    <div class="engine-card">
                        <div ct-app id="ct-mount-point">
                            </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer style="text-align: center; padding: 40px; color: #999; font-size: 13px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        var CT = {
          ABE: {
            Settings: {
              clientID: '315556',
              type: window.innerWidth < 800 ? 'mobile' : 'desktop',
              step1: {
                deeplinkURL: 'https://book.cartrawler.com/?clientID=315556',
                showAvailNewWindow: false
              }
            }
          }
        };

        (function() {
          CT.ABE.Settings.version = '5.0';
          var cts = document.createElement('script'); 
          cts.type = 'text/javascript'; cts.async = true;
          cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
          var s = document.getElementsByTagName('script')[0]; 
          s.parentNode.insertBefore(cts, s);
        })();

        /* --- THE COLOR AND PADDING POLICE --- */
        const tidyUp = setInterval(() => {
            const btn = document.querySelector('.ct-btn-search');
            const ctContainer = document.querySelector('.ct-search-container');
            
            if (btn) {
                // Force button color
                btn.style.setProperty('background-color', '#2BA6CB', 'important');
                btn.style.setProperty('background-image', 'none', 'important');
                
                // Kill internal CT margins that cause the "edge-to-edge" issue
                if (ctContainer) {
                    ctContainer.style.setProperty('margin', '0', 'important');
                    ctContainer.style.setProperty('padding', '0', 'important');
                }
                
                clearInterval(tidyUp);
            }
        }, 300);
    </script>
</body>
</html>