---
// Auto Reservation Plus - Step 1 Horizontal Build
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Auto Reservation Plus | Holiday Car Rentals</title>
    <style>
        :root { --brand-blue: #2BA6CB; --dark-text: #333; --light-bg: #f4f4f4; }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: var(--light-bg); color: var(--dark-text); }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header & Nav */
        header { background: white; padding: 15px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); text-transform: uppercase; font-size: 1.4rem; letter-spacing: 1px; }
        .phone { font-weight: bold; color: var(--brand-blue); font-size: 0.9rem; }
        
        nav { background: #333; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 12px 20px; color: white; text-decoration: none; font-weight: 600; font-size: 14px; transition: 0.2s; }
        nav .nav-flex li a:hover { background-color: var(--brand-blue) !important; }

        /* --- HERO SECTION --- */
        .hero-wrapper {
            width: 100%;
            height: 550px; /* Increased slightly to balance the row */
            background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.1)), 
                        url('https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
        .hero-text { color: white; margin-bottom: 40px; }
        .hero-text h1 { font-size: 3.5rem; margin: 0; text-shadow: 0 2px 15px rgba(0,0,0,0.4); font-weight: 800; }
        .hero-text p { font-size: 1.2rem; margin-top: 5px; font-weight: 400; text-shadow: 0 1px 5px rgba(0,0,0,0.5); }

        /* --- THE HORIZONTAL SEARCH BAR --- */
        .search-row-container {
            width: 100%;
            margin-top: -80px; /* Pulls the bar up into the image */
            position: relative;
            z-index: 10;
        }
        .engine-container {
            background: rgba(255, 255, 255, 0.98);
            padding: 5px; /* Minimal padding is key for horizontal layout */
            border-radius: 6px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* --- CUSTOMIZING THE ENGINE BUTTON (HACK) --- */
        /* This tries to force the CarTrawler button to match your blue */
        [ct-app] .ct-btn-search {
            background-color: var(--brand-blue) !important;
            border-color: var(--brand-blue) !important;
        }

        @media (max-width: 1024px) {
            .hero-text h1 { font-size: 2.5rem; }
            .hero-wrapper { height: 450px; }
            .search-row-container { margin-top: -40px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="container top-flex">
            <div class="logo-area"><h2>Auto Reservation Plus</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav>
        <div class="container">
            <ul class="nav-flex">
                <li><a href="/">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <div class="hero-wrapper">
        <div class="hero-text">
            <h1>Holiday Car Rentals</h1>
            <p>Compare 800+ suppliers at 30,000 locations worldwide</p>
        </div>
    </div>

    <div class="search-row-container">
        <div class="container">
            <div class="engine-container">
                <div ct-app>
                    </div>
            </div>
        </div>
    </div>

    <footer style="text-align: center; padding: 100px 20px; color: #999; font-size: 13px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        var CT = {
          ABE: {
            Settings: {
              clientID: '315556',
              type: window.innerWidth < 800 ? 'mobile' : 'desktop',
              step1: {
                deeplinkURL: 'https://book.cartrawler.com/?clientID=315556',
                showAvailNewWindow: false
              }
            }
          }
        };

        (function() {
          CT.ABE.Settings.version = '5.0';
          var cts = document.createElement('script'); 
          cts.type = 'text/javascript'; cts.async = true;
          cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
          var s = document.getElementsByTagName('script')[0]; 
          s.parentNode.insertBefore(cts, s);
        })();
    </script>
</body>
</html>