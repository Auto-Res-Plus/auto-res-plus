---
// Auto Reservation Plus - Amalfi Edition
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Holiday Car Rentals | Auto Reservation Plus</title>
    <style is:global>
        :root { 
            --brand-blue: #2BA6CB; 
            --dark-text: #333; 
            --light-bg: #f4f4f4; 
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: var(--light-bg); line-height: 1.6; color: var(--dark-text); }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header & Nav */
        header { background: white; padding: 15px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); text-transform: uppercase; font-size: 1.3rem; letter-spacing: 1px; }
        .phone { font-weight: bold; color: var(--brand-blue); font-size: 0.9rem; }
        
        nav { background: #333; position: sticky; top: 0; z-index: 1000; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 12px 20px; color: white; text-decoration: none; font-weight: 600; font-size: 14px; }
        nav .nav-flex li a:hover { background-color: var(--brand-blue) !important; }

        /* --- THE GRID HERO --- */
        .hero-grid-wrapper {
            width: 100%;
            min-height: 600px;
            /* AMALFI COAST GEN IMAGE */
            background-color: #222;
            background-image: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.1)), 
                              url('/amalfi-rental-v2.webp');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .hero-grid { 
            display: grid; 
            grid-template-columns: 1.3fr 0.7fr; /* Slight wider left side */
            gap: 60px; 
            align-items: center;
            width: 100%;
            max-width: 1200px;
        }
        
        .hero-left-text { color: white; }
        .hero-left-text h1 { font-size: 3.5rem; margin: 0; line-height: 1; font-weight: 800; text-shadow: 0 2px 20px rgba(0,0,0,0.4); }
        
        .check-list { list-style: none; padding: 0; margin: 30px 0 0 0; }
        .check-list li { font-size: 1.3rem; margin-bottom: 12px; display: flex; align-items: center; text-shadow: 0 1px 10px rgba(0,0,0,0.5); }
        .check-list li::before {
            content: '✓'; display: inline-block; width: 28px; height: 28px; background: var(--brand-blue);
            color: white; border-radius: 50%; text-align: center; line-height: 28px; margin-right: 15px; font-weight: bold; font-size: 16px;
        }

        /* --- THE CLEAN SEARCH BOX --- */
        .engine-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.4);
            padding: 10px; /* Internal buffer */
            width: 100%;
            max-width: 420px;
            margin-left: auto;
            position: relative;
        }

        /* Forces the widget background to be white/transparent */
        div[ct-app] .ct-step-1-container,
        div[ct-app] .ct-search-container,
        div[ct-app] .ct-engine-step-1 { 
            background: #ffffff !important; 
            border: none !important; 
            box-shadow: none !important;
            border-radius: 8px !important;
        }

        /* FORCES THE SEARCH BUTTON TO BRAND BLUE */
        div[ct-app] .ct-btn-search,
        div[ct-app] button.ct-btn-search,
        div[ct-app] .ct-search-button-container button {
            background: var(--brand-blue) !important;
            background-color: var(--brand-blue) !important;
            color: #ffffff !important;
            border: none !important;
            text-transform: uppercase !important;
            font-weight: bold !important;
            background-image: none !important; /* Removes default gradients */
            height: 55px !important;
            border-radius: 4px !important;
        }

        @media (max-width: 992px) {
            .hero-grid { grid-template-columns: 1fr; padding: 20px 0; text-align: center; }
            .hero-left-text h1 { font-size: 2.8rem; }
            .engine-card { margin: 20px auto 0; }
            .check-list { display: inline-block; text-align: left; margin: 30px auto; }
        }
    </style>
</head>
<body id="main-body">

    <header>
        <div class="container top-flex">
            <div class="logo-area"><h2>Auto Reservation Plus</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav>
        <div class="container">
            <ul class="nav-flex">
                <li><a href="/">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero-grid-wrapper">
        <div class="hero-grid">
            <div class="hero-left-text">
                <h1>Holiday Car Rentals</h1>
                <ul class="check-list">
                    <li>Free Cancellation</li>
                    <li>No Hidden Charges</li>
                    <li>800+ Suppliers Worldwide</li>
                    <li>24/7 Global Support</li>
                </ul>
            </div>
            <div class="hero-right-engine">
                <div class="engine-card">
                    <div ct-app id="ct-mount-point">
                        </div>
                </div>
            </div>
        </div>
    </section>

    <footer style="text-align: center; padding: 60px; color: #999; font-size: 13px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        /* --- CARTRAWLER CONFIG --- */
        var CT = {
          ABE: {
            Settings: {
              clientID: '315556',
              type: window.innerWidth < 992 ? 'mobile' : 'desktop',
              step1: {
                deeplinkURL: 'https://book.cartrawler.com/?clientID=315556',
                showAvailNewWindow: false
              }
            }
          }
        };

        (function() {
          CT.ABE.Settings.version = '5.0';
          var cts = document.createElement('script'); 
          cts.type = 'text/javascript'; cts.async = true;
          cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
          var s = document.getElementsByTagName('script')[0]; 
          s.parentNode.insertBefore(cts, s);
        })();

        /* --- THE STUBBORN COLOR FIXER --- */
        // Force the button color one last time with Javascript
        const colorFixer = setInterval(() => {
            const btn = document.querySelector('.ct-btn-search');
            if (btn) {
                btn.style.setProperty('background-color', '#2BA6CB', 'important');
                btn.style.setProperty('background-image', 'none', 'important');
                clearInterval(colorFixer);
            }
        }, 300);
    </script>
</body>
</html>