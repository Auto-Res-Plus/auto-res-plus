---
// Auto Reservation Plus - Centered Stack Layout
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staging | Auto Reservation Plus</title>
    <style>
        :root { 
            --brand-blue: #2BA6CB; 
            --dark-text: #333;
            --light-bg: #f4f4f4;
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; background: var(--light-bg); color: var(--dark-text); line-height: 1.6; }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header */
        .top-bar { background: white; padding: 20px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); letter-spacing: -1px; font-size: 1.5rem; }
        .phone { font-weight: bold; color: var(--brand-blue); }

        /* Nav */
        nav.main-nav { background: #333; color: white; position: sticky; top: 0; z-index: 100; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 15px 20px; color: white; text-decoration: none; font-size: 14px; font-weight: bold; }
        .mobile-toggle { display: none; background: none; border: none; color: white; font-size: 24px; padding: 10px; cursor: pointer; }

        /* --- HERO SECTION (CENTRE STACK) --- */
        .hero-wrapper {
            width: 100%;
            min-height: 700px;
            background-color: #222; /* Fallback color */
            background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), 
                              url('https://images.unsplash.com/photo-1519003722824-191d44fbd50d?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 80px 20px;
        }

        .hero-text { color: white; margin-bottom: 40px; }
        .hero-text h1 { font-size: 4rem; color: white; margin: 0; text-shadow: 0 2px 15px rgba(0,0,0,0.5); }
        .hero-text p { font-size: 1.4rem; opacity: 0.9; margin-top: 10px; }

        /* Centered Engine Container */
        .engine-container {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 850px; /* Centered but not full width */
            transition: max-width 0.5s ease;
            margin: 0 auto;
            min-height: 450px;
        }

        /* Expand the engine to full container width when results load */
        .engine-container.expanded {
            max-width: 1200px;
        }

        /* Mobile Adjustments */
        @media (max-width: 768px) {
            .hero-text h1 { font-size: 2.5rem; }
            .mobile-toggle { display: block; }
            .nav-flex { display: none; }
            .hero-wrapper { min-height: 600px; padding: 40px 15px; }
        }

        /* Mobile Panel */
        #mobile-panel { position: fixed; top: 0; left: -100%; width: 250px; height: 100%; background: #333; transition: 0.3s; z-index: 1000; padding: 20px; }
        #mobile-panel.open { left: 0; }
        #mobile-panel a { display: block; color: white; padding: 15px 0; text-decoration: none; border-bottom: 1px solid #444; }
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: none; z-index: 999; }
        .overlay.active { display: block; }
    </style>
</head>
<body>

    <div id="mobile-panel">
        <button id="close-btn" style="color: white; background: none; border: none; font-size: 30px; cursor: pointer;">&times;</button>
        <a href="#">Home</a>
        <a href="#">Manage Booking</a>
        <a href="#">Contact Us</a>
    </div>
    <div class="overlay" id="overlay"></div>

    <header class="top-bar">
        <div class="container top-flex">
            <div class="logo-area"><h2>AUTO RESERVATION PLUS</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav class="main-nav">
        <div class="container">
            <button class="mobile-toggle" id="menu-btn">☰</button>
            <ul class="nav-flex">
                <li><a href="#">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero-wrapper">
        <div class="hero-text">
            <h1>Holiday Car Rentals</h1>
            <p>Quality car hire at over 30,000 locations worldwide</p>
        </div>

        <div class="engine-container" id="engine-box">
            <div ct-app>
                <noscript>YOUR BROWSER DOES NOT SUPPORT JAVASCRIPT</noscript>
            </div>
        </div>
    </section>

    <footer style="text-align: center; padding: 40px; color: #999; font-size: 13px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        /* --- 1. CARTRAWLER V5 --- */
        var isMobile = window.innerWidth <= 768;
        var CT = { ABE: { Settings: { clientID: '315556' } } };
        if (isMobile) { CT.ABE.Settings.type = 'mobile'; }

        (function() {
            CT.ABE.Settings.version = '5.0';
            var cts = document.createElement('script'); 
            cts.type = 'text/javascript'; cts.async = true;
            cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
            var s = document.getElementsByTagName('script')[0]; 
            s.parentNode.insertBefore(cts, s);
        })();

        /* --- 2. ENGINE OBSERVER (Expansion) --- */
        // Watches the engine box. If results appear, it expands the white box.
        const targetNode = document.getElementById('engine-box');
        const observer = new MutationObserver(function() {
            if (document.querySelector('.ct-results-container, .ct-engine-step-2')) {
                targetNode.classList.add('expanded');
                // Optional: hide the strapline once results show to save space
                document.querySelector('.hero-text').style.display = 'none';
                window.scrollTo({ top: 100, behavior: 'smooth' });
                observer.disconnect();
            }
        });
        observer.observe(targetNode, { childList: true, subtree: true });

        /* --- 3. MOBILE MENU --- */
        const menuBtn = document.getElementById('menu-btn');
        const closeBtn = document.getElementById('close-btn');
        const panel = document.getElementById('mobile-panel');
        const overlay = document.getElementById('overlay');

        if (menuBtn) {
            menuBtn.addEventListener('click', () => {
                panel.classList.add('open');
                overlay.classList.add('active');
            });
            const closeMenu = () => {
                panel.classList.remove('open');
                overlay.classList.remove('active');
            };
            if (closeBtn) closeBtn.addEventListener('click', closeMenu);
            overlay.addEventListener('click', closeMenu);
        }
    </script>
</body>
</html>