---
// Auto Reservation Plus - Production Staging
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staging | Auto Reservation Plus</title>
    <style>
        :root { 
            --brand-blue: #2BA6CB; 
            --dark-text: #333;
            --light-bg: #f4f4f4;
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; background: var(--light-bg); color: var(--dark-text); line-height: 1.6; }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header */
        .top-bar { background: white; padding: 20px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); letter-spacing: -1px; font-size: 1.5rem; }
        .phone { font-weight: bold; color: var(--brand-blue); }

        /* Nav */
        nav.main-nav { background: #333; color: white; position: sticky; top: 0; z-index: 100; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 15px 20px; color: white; text-decoration: none; font-size: 14px; font-weight: bold; transition: background 0.2s; }
        .nav-flex li a:hover { background: var(--brand-blue); }

        .mobile-toggle { display: none; background: none; border: none; color: white; font-size: 24px; padding: 10px; cursor: pointer; }

        /* --- HERO SECTION --- */
        .hero-wrapper {
            width: 100%;
            min-height: 600px;
            /* High-res Unsplash image with a 60% dark tint for readability */
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), 
                        url('https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            padding: 60px 0;
            transition: min-height 0.5s ease;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr; /* Slightly wider left side for text */
            gap: 40px;
            align-items: start;
            width: 100%;
        }

        /* The Hero Text */
        .hero-text { color: white; }
        .hero-text h1 { font-size: 3.5rem; color: white; margin: 0 0 20px 0; line-height: 1.1; }
        .hero-text p { font-size: 1.2rem; margin-bottom: 30px; }
        .hero-bullets { list-style: none; padding: 0; }
        .hero-bullets li { margin-bottom: 12px; font-size: 1.1rem; display: flex; align-items: center; gap: 10px; }

        /* The Engine Container */
        .engine-container {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            width: 100%;
            min-height: 450px; /* Prevents layout jump */
        }

        /* --- THE MAGIC FIX: SEARCH ACTIVE STATE --- */
        /* We use !important here to ensure it overrides the 1.2fr 0.8fr grid */
        .hero-grid.search-active {
            grid-template-columns: 1fr !important;
        }

        .hero-grid.search-active .hero-text {
            display: none !important;
        }

        /* Mobile Menu Panel */
        #mobile-panel { position: fixed; top: 0; left: -100%; width: 250px; height: 100%; background: #333; transition: 0.3s; z-index: 1000; padding: 20px; }
        #mobile-panel.open { left: 0; }
        #mobile-panel a { display: block; color: white; padding: 15px 0; text-decoration: none; border-bottom: 1px solid #444; }
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: none; z-index: 999; }
        .overlay.active { display: block; }

        @media (max-width: 900px) {
            .hero-grid { grid-template-columns: 1fr !important; }
            .hero-text { text-align: center; margin-bottom: 40px; }
            .hero-text h1 { font-size: 2.5rem; }
            .mobile-toggle { display: block; }
            .nav-flex { display: none; }
        }
    </style>
</head>
<body>

    <div id="mobile-panel">
        <button id="close-btn" style="color: white; background: none; border: none; font-size: 30px; cursor: pointer;">&times;</button>
        <a href="#">Home</a>
        <a href="#">Manage Booking</a>
        <a href="#">Contact Us</a>
    </div>
    <div class="overlay" id="overlay"></div>

    <header class="top-bar">
        <div class="container top-flex">
            <div class="logo-area"><h2>AUTO RESERVATION PLUS</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav class="main-nav">
        <div class="container">
            <button class="mobile-toggle" id="menu-btn">☰</button>
            <ul class="nav-flex">
                <li><a href="#">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero-wrapper">
        <div class="container hero-grid" id="main-hero-grid">
            <div class="hero-text">
                <h1>Premium Car & Van Hire</h1>
                <p>Compare 800+ suppliers in 30,000 locations worldwide.</p>
                <ul class="hero-bullets">
                    <li>✓ Free Cancellation</li>
                    <li>✓ No Hidden Fees</li>
                    <li>✓ 24/7 Global Support</li>
                </ul>
            </div>

            <div class="engine-container">
                <div ct-app>
                    <noscript>YOUR BROWSER DOES NOT SUPPORT JAVASCRIPT</noscript>
                </div>
            </div>
        </div>
    </section>

    <footer style="text-align: center; padding: 40px; color: #999; font-size: 13px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        /* --- 1. CARTRAWLER V5 --- */
        var isMobile = window.innerWidth <= 768;
        var CT = { ABE: { Settings: { clientID: '315556' } } };
        if (isMobile) { CT.ABE.Settings.type = 'mobile'; }

        (function() {
            CT.ABE.Settings.version = '5.0';
            var cts = document.createElement('script'); 
            cts.type = 'text/javascript'; cts.async = true;
            cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
            var s = document.getElementsByTagName('script')[0]; 
            s.parentNode.insertBefore(cts, s);
        })();

        /* --- 2. LAYOUT SWITCHER --- */
        // We use a more aggressive listener for V5 buttons
        document.addEventListener('click', function (e) {
            // Check for the search button ID or the text 'Search'
            if (e.target && (e.target.id === 'ct-search-btn' || e.target.innerText === 'Search' || e.target.closest('#ct-search-btn'))) {
                const grid = document.getElementById('main-hero-grid');
                if (grid) {
                    grid.classList.add('search-active');
                    console.log("Layout expanded to full width");
                    window.scrollTo({ top: 100, behavior: 'smooth' });
                }
            }
        });

        /* --- 3. MOBILE MENU --- */
        const menuBtn = document.getElementById('menu-btn');
        const closeBtn = document.getElementById('close-btn');
        const panel = document.getElementById('mobile-panel');
        const overlay = document.getElementById('overlay');

        if (menuBtn) {
            menuBtn.addEventListener('click', () => {
                panel.classList.add('open');
                overlay.classList.add('active');
            });
            const closeMenu = () => {
                panel.classList.remove('open');
                overlay.classList.remove('active');
            };
            closeBtn.addEventListener('click', closeMenu);
            overlay.addEventListener('click', closeMenu);
        }
    </script>
</body>
</html>