---
// Auto Reservation Plus - Force-Hide Background Build
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staging | Auto Reservation Plus</title>
    <style>
        :root { 
            --brand-blue: #2BA6CB; 
            --dark-text: #333;
            --light-bg: #f4f4f4;
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; background: var(--light-bg); color: var(--dark-text); line-height: 1.6; }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header & Nav */
        .top-bar { background: white; padding: 20px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); letter-spacing: -1px; font-size: 1.5rem; }
        .phone { font-weight: bold; color: var(--brand-blue); }
        nav.main-nav { background: #333; color: white; position: sticky; top: 0; z-index: 100; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 15px 25px; color: white; text-decoration: none; font-size: 14px; font-weight: bold; }
        nav.main-nav .nav-flex li a:hover { background-color: var(--brand-blue) !important; }

        /* --- HERO WRAPPER --- */
        .hero-wrapper {
            width: 100%;
            min-height: 550px;
            /* Initial Sunny Background */
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), 
                        url('https://images.unsplash.com/photo-1501179691627-eeaa65ea017c?q=80&w=2000&auto=format&fit=crop') no-repeat center center;
            background-size: cover;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 60px 0;
            transition: all 0.4s ease;
        }

        .hero-text { color: white; text-align: center; margin-bottom: 30px; }
        .hero-text h1 { font-size: 3.5rem; color: white; margin: 0; text-shadow: 0 4px 10px rgba(0,0,0,0.3); }

        .engine-container {
            background: white;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* --- THE CRITICAL FIX: HIDE BACKGROUND --- */
        /* We add this class via JavaScript when results load */
        body.is-searching .hero-wrapper {
            background: #f4f4f4 !important; /* Force background to light gray */
            background-image: none !important; /* Kill the image */
            min-height: auto !important; /* Shrink the header height */
            padding: 20px 0 !important;
        }

        body.is-searching .hero-text {
            display: none !important; /* Kill the text */
        }

        /* Mobile Menu */
        #mobile-panel { position: fixed; top: 0; left: -100%; width: 250px; height: 100%; background: #333; transition: 0.3s; z-index: 1000; padding: 20px; }
        #mobile-panel.open { left: 0; }
        #mobile-panel a { display: block; color: white; padding: 15px 0; text-decoration: none; }
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: none; z-index: 999; }
        .overlay.active { display: block; }

        @media (max-width: 768px) {
            .nav-flex { display: none; }
            .hero-text h1 { font-size: 2.2rem; }
        }
    </style>
</head>
<body id="main-body">

    <div id="mobile-panel">
        <button id="close-btn" style="color: white; background: none; border: none; font-size: 30px; cursor: pointer;">&times;</button>
        <a href="#">Home</a>
        <a href="#">Manage Booking</a>
        <a href="#">Contact Us</a>
    </div>
    <div class="overlay" id="overlay"></div>

    <header class="top-bar">
        <div class="container top-flex">
            <div class="logo-area"><h2>AUTO RESERVATION PLUS</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav class="main-nav">
        <div class="container">
            <ul class="nav-flex">
                <li><a href="#">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <section class="hero-wrapper">
        <div class="hero-text" id="strapline">
            <h1>Holiday Car Rentals</h1>
            <p>Quality car hire at over 30,000 locations worldwide</p>
        </div>

        <div class="container">
            <div class="engine-container" id="engine-box">
                <div ct-app>
                    <noscript>YOUR BROWSER DOES NOT SUPPORT JAVASCRIPT</noscript>
                </div>
            </div>
        </div>
    </section>

    <footer style="text-align: center; padding: 40px; color: #999; font-size: 13px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        /* --- 1. CARTRAWLER LOADER --- */
        var CT = { ABE: { Settings: { clientID: '315556' } } };
        if (window.innerWidth <= 768) { CT.ABE.Settings.type = 'mobile'; }

        (function() {
            CT.ABE.Settings.version = '5.0';
            var cts = document.createElement('script'); 
            cts.type = 'text/javascript'; cts.async = true;
            cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
            document.getElementsByTagName('script')[0].parentNode.insertBefore(cts, document.getElementsByTagName('script')[0]);
        })();

        /* --- 2. THE FORCE-HIDE OBSERVER --- */
        // This is much faster than a timer. It watches for ANY change in the engine box.
        const engineBox = document.getElementById('engine-box');
        const bodyTag = document.getElementById('main-body');

        const observer = new MutationObserver(function() {
            // If we see the results container OR the loading spinner, switch modes
            if (document.querySelector('.ct-results-container, .ct-loading-container, .ct-car-list, .ct-engine-step-2')) {
                bodyTag.classList.add('is-searching');
                // Optional: scroll to show the results nicely
                window.scrollTo({ top: 120, behavior: 'smooth' });
            }
        });

        // Start watching the engine box for results arriving
        observer.observe(engineBox, { childList: true, subtree: true });

        /* --- 3. OVERLAY/PANEL LOGIC --- */
        const overlay = document.getElementById('overlay');
        const panel = document.getElementById('mobile-panel');
        if (overlay && panel) {
            overlay.addEventListener('click', () => {
                panel.classList.remove('open');
                overlay.classList.remove('active');
            });
        }
    </script>
</body>
</html>