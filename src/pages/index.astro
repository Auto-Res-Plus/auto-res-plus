---
// Auto Reservation Plus - Option 1: Step 1 Redirect Build
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Holiday Car Rentals | Auto Reservation Plus</title>
    <style>
        :root { --brand-blue: #2BA6CB; --dark-text: #333; --light-bg: #f4f4f4; }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: Arial, sans-serif; background: var(--light-bg); color: var(--dark-text); }
        
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
        
        /* Header & Nav */
        header { background: white; padding: 15px 0; border-bottom: 1px solid #eee; }
        .top-flex { display: flex; justify-content: space-between; align-items: center; }
        .logo-area h2 { margin:0; color: var(--brand-blue); text-transform: uppercase; font-size: 1.5rem; }
        .phone { font-weight: bold; color: var(--brand-blue); }
        
        nav { background: #333; }
        .nav-flex { display: flex; list-style: none; margin: 0; padding: 0; }
        .nav-flex li a { display: block; padding: 15px 25px; color: white; text-decoration: none; font-weight: bold; }
        nav .nav-flex li a:hover { background-color: var(--brand-blue) !important; }

        /* --- HERO SECTION --- */
        .hero-wrapper {
            width: 100%;
            height: 500px;
            background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.2)), 
                        url('https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .hero-text { color: white; text-align: center; margin-bottom: 30px; }
        .hero-text h1 { font-size: 3.5rem; margin: 0; text-shadow: 0 2px 15px rgba(0,0,0,0.4); }

        /* --- HORIZONTAL SEARCH BAR --- */
        .search-row {
            width: 100%;
            margin-top: -60px; /* Pulls it up into the hero */
        }
        .engine-container {
            background: white;
            padding: 10px 5px; /* Extremely tight padding to force horizontal */
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            min-height: 80px;
        }

        @media (max-width: 900px) {
            .hero-text h1 { font-size: 2.2rem; }
            .search-row { margin-top: 0; padding: 20px 0; }
        }
    </style>
</head>
<body>

    <header>
        <div class="container top-flex">
            <div class="logo-area"><h2>Auto Reservation Plus</h2></div>
            <div class="phone">Tel: +44(0)1622 631146</div>
        </div>
    </header>

    <nav>
        <div class="container">
            <ul class="nav-flex">
                <li><a href="/">Home</a></li>
                <li><a href="#">Manage Booking</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <div class="hero-wrapper">
        <div class="hero-text">
            <h1>Holiday Car Rentals</h1>
            <p>Quality car hire at over 30,000 locations worldwide</p>
        </div>
    </div>

    <div class="search-row">
        <div class="container">
            <div class="engine-container">
                <div ct-app>
                    </div>
            </div>
        </div>
    </div>

    <footer style="text-align: center; padding: 80px 20px; color: #999; font-size: 12px;">
        &copy; 2026 Auto Reservation Plus Limited
    </footer>

    <script is:inline>
        /* --- MERGED CARTRAWLER OPTION 1 CONFIG --- */
        var CT = {
          ABE: {
            Settings: {
              clientID: '315556',
              // This handles the mobile detection mentioned in Option 5
              type: window.innerWidth < 768 ? 'mobile' : 'desktop',
              step1: {
                // Redirects to the full results page on their secure server
                deeplinkURL: 'https://book.cartrawler.com/?clientID=315556',
                showAvailNewWindow: false // Set to true if you want a popup instead
              }
            }
          }
        };

        (function() {
          CT.ABE.Settings.version = '5.0';
          var cts = document.createElement('script'); 
          cts.type = 'text/javascript'; cts.async = true;
          cts.src = 'https://ajaxgeo.cartrawler.com/abe5.0/ct_loader.js?' + new Date().getTime();
          var s = document.getElementsByTagName('script')[0]; 
          s.parentNode.insertBefore(cts, s);
        })();
    </script>
</body>
</html>